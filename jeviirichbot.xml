<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="current_stake">current_stake</variable>
    <variable id="current_prediction">current_prediction</variable>
    <variable id="total_profit_loss">total_profit_loss</variable>
    <variable id="is_in_trade">is_in_trade</variable>
    <variable id="contract_id">contract_id</variable>
    <variable id="profit">profit</variable>
  </variables>

  <!-- Main Strategy Block -->
  <block type="trade_definition_market" id="market_block" x="50" y="50">
    <field name="MARKET_LIST">synthetic_index</field>
    <field name="SYMBOL_LIST">R_25</field>
    <next>
      <block type="trade_definition_contract" id="contract_block">
        <field name="TRADETYPE_LIST">DIGITUNDER</field>
        <field name="DURATIONTYPE_LIST">t</field>
        <field name="DURATION">1</field>
        <field name="CURRENCY_LIST">USD</field>
        <field name="AMOUNT">0.5</field>
        <next>
          <block type="trade_definition_restart" id="restart_block">
            <next>
              <block type="during_purchase" id="during_purchase_block">
                <next>
                  <block type="after_purchase" id="after_purchase_block">
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>

</xml>